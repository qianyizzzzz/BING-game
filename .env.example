# Server runtime
PORT=3001
PUBLIC_DIR=apps/client/dist
CLIENT_ORIGIN=http://localhost:5173
# Comma-separated production origins allowed by Express and Socket.IO.
# Example: PUBLIC_ORIGINS=https://your-domain.com
PUBLIC_ORIGINS=
CLIENT_ORIGINS=
# Set to true only for temporary tunnel play, such as npm run public.
ALLOW_TUNNEL_ORIGINS=false
ACCOUNT_DATA_FILE=data/accounts/accounts.json

# Client build time
VITE_SERVER_URL=http://localhost:3001
