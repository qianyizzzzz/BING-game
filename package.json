{
  "name": "bing-card-game",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c green,cyan \"npm run dev -w @bing/server\" \"npm run dev -w @bing/client\"",
    "dev:server": "npm run dev -w @bing/server",
    "dev:client": "npm run dev -w @bing/client",
    "serve": "tsx apps/server/src/index.ts",
    "build": "npm run build -w @bing/shared && npm run build -w @bing/server && npm run build -w @bing/client",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "import:skills": "python scripts/import-skills.py",
    "training:export": "node scripts/export-training-data.mjs",
    "training:selfplay": "tsx scripts/self-play-training.ts",
    "training:selfplay:2h": "tsx scripts/self-play-training.ts --duration-minutes 120 --skill-heavy"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "express": "^5.1.0",
    "lucide-react": "^0.468.0",
    "postcss": "^8.5.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.12"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/node": "^24.9.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2"
  }
}
